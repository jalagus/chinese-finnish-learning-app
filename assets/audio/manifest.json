  "stories": {
    "morning-hello": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Liisa näkee ystävänsä bussipysäkillä. Hän sanoo: Moi!",
          "path": "stories/morning-hello/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Ystävä hymyilee ja vastaa: Moi, Liisa! Mitä kuuluu?",
          "path": "stories/morning-hello/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Liisa sanoo: Hyvää kuuluu. Kiitos! Ja sinä?",
          "path": "stories/morning-hello/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Ystävä sanoo: Kyllä, kaikki on hyvin. Bussi tulee pian.",
          "path": "stories/morning-hello/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Aamun tervehdys",
        "path": "stories/morning-hello/title.wav"
      }
    },
    "water-at-cafe": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Wei menee pieneen kahvilaan Helsingissä.",
          "path": "stories/water-at-cafe/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Hän sanoo tarjoilijalle: Anteeksi, haluan vettä.",
          "path": "stories/water-at-cafe/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Tarjoilija kysyy: Haluatko myös kahvia?",
          "path": "stories/water-at-cafe/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Wei vastaa: Ei, kiitos. Vettä on hyvä.",
          "path": "stories/water-at-cafe/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Vettä kahvilassa",
        "path": "stories/water-at-cafe/title.wav"
      }
    },
    "train-to-school": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Minä opiskelen suomea ja menen kouluun junalla.",
          "path": "stories/train-to-school/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Aamulla juna on hiljainen, ja minä luen kirjaa.",
          "path": "stories/train-to-school/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Koulussa ystäväni sanoo: Sinun suomi on parempi nyt!",
          "path": "stories/train-to-school/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Minä hymyilen ja sanon: Kiitos, minä harjoittelen joka päivä.",
          "path": "stories/train-to-school/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Juna kouluun",
        "path": "stories/train-to-school/title.wav"
      }
    },
    "breakfast-at-home": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Aamulla Mei on kotona ja tekee aamiaista.",
          "path": "stories/breakfast-at-home/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Pöydällä on leipää, maitoa ja yksi omena.",
          "path": "stories/breakfast-at-home/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Mei ajattelee: Tänään minä opiskelen paljon suomea.",
          "path": "stories/breakfast-at-home/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Aamiainen on pieni, mutta hyvä.",
          "path": "stories/breakfast-at-home/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Aamiainen kotona",
        "path": "stories/breakfast-at-home/title.wav"
      }
    },
    "ticket-at-station": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Chen tulee asemalle vähän myöhässä.",
          "path": "stories/ticket-at-station/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Hän kysyy: Anteeksi, missä voin ostaa lipun?",
          "path": "stories/ticket-at-station/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Työntekijä sanoo: Lippuautomaatti on tuolla oikealla.",
          "path": "stories/ticket-at-station/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Chen kysyy vielä: Milloin juna lähtee? Työntekijä vastaa: Nyt pian.",
          "path": "stories/ticket-at-station/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Lippu asemalla",
        "path": "stories/ticket-at-station/title.wav"
      }
    },
    "new-student": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Lin on uusi opiskelija suomalaisessa koulussa.",
          "path": "stories/new-student/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Opettaja sanoo: Hei! Tervetuloa luokkaan.",
          "path": "stories/new-student/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Lin sanoo: Hei, minä olen Lin. Olen kotoisin Kiinasta.",
          "path": "stories/new-student/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Opettaja hymyilee ja sanoo: Sinun suomi alkaa hyvin.",
          "path": "stories/new-student/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Uusi opiskelija",
        "path": "stories/new-student/title.wav"
      }
    },
    "weather-today": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Tänään ulkona on kylmä, mutta aurinko paistaa.",
          "path": "stories/weather-today/paragraphs/01.wav"
        },
        {
          "index": 2,
          "text": "Minä laitan lämpimän takin päälle ja menen bussiin.",
          "path": "stories/weather-today/paragraphs/02.wav"
        },
        {
          "index": 3,
          "text": "Ystäväni sanoo: Huomenna on ehkä lämpimämpi päivä.",
          "path": "stories/weather-today/paragraphs/03.wav"
        },
        {
          "index": 4,
          "text": "Minä vastaan: Se on hyvä uutinen.",
          "path": "stories/weather-today/paragraphs/04.wav"
        }
      ],
      "title": {
        "text": "Sää tänään",
        "path": "stories/weather-today/title.wav"
