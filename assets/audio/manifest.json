          "path": "stories/morning-hello/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Liisa sanoo: Hyvää, kiitos! Entä sinulle?",
          "path": "stories/morning-hello/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Ystävä sanoo: Kiitos, kaikki on hyvin. Bussi tulee pian.",
          "path": "stories/morning-hello/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Aamun tervehdys",
        "path": "stories/morning-hello/title.mp3"
      }
    },
    "water-at-cafe": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Wei menee pieneen kahvilaan Helsingissä.",
          "path": "stories/water-at-cafe/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Hän sanoo tarjoilijalle: Anteeksi, haluan vettä.",
          "path": "stories/water-at-cafe/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Tarjoilija kysyy: Haluatko myös kahvia?",
          "path": "stories/water-at-cafe/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Wei vastaa: Ei, kiitos. Vesi riittää.",
          "path": "stories/water-at-cafe/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Vettä kahvilassa",
        "path": "stories/water-at-cafe/title.mp3"
      }
    },
    "train-to-school": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Minä opiskelen suomea ja menen kouluun junalla.",
          "path": "stories/train-to-school/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Aamulla juna on hiljainen, ja minä luen kirjaa.",
          "path": "stories/train-to-school/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Koulussa ystäväni sanoo: Sinun suomesi on nyt parempaa!",
          "path": "stories/train-to-school/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Minä hymyilen ja sanon: Kiitos, minä harjoittelen joka päivä.",
          "path": "stories/train-to-school/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Juna kouluun",
        "path": "stories/train-to-school/title.mp3"
      }
    },
    "breakfast-at-home": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Aamulla Mei on kotona ja tekee aamiaista.",
          "path": "stories/breakfast-at-home/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Pöydällä on leipää, maitoa ja yksi omena.",
          "path": "stories/breakfast-at-home/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Mei ajattelee: Tänään minä opiskelen paljon suomea.",
          "path": "stories/breakfast-at-home/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Aamiainen on pieni, mutta hyvä.",
          "path": "stories/breakfast-at-home/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Aamiainen kotona",
        "path": "stories/breakfast-at-home/title.mp3"
      }
    },
    "ticket-at-station": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Chen tulee asemalle vähän myöhässä.",
          "path": "stories/ticket-at-station/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Hän kysyy: Anteeksi, missä voin ostaa lipun?",
          "path": "stories/ticket-at-station/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Työntekijä sanoo: Lippuautomaatti on tuolla oikealla.",
          "path": "stories/ticket-at-station/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Chen kysyy vielä: Milloin juna lähtee? Työntekijä vastaa: Se lähtee ihan pian.",
          "path": "stories/ticket-at-station/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Lippu asemalla",
        "path": "stories/ticket-at-station/title.mp3"
      }
    },
    "new-student": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Lin on uusi opiskelija suomalaisessa koulussa.",
          "path": "stories/new-student/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Opettaja sanoo: Hei! Tervetuloa luokkaan.",
          "path": "stories/new-student/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Lin sanoo: Hei, minä olen Lin. Olen kotoisin Kiinasta.",
          "path": "stories/new-student/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Opettaja hymyilee ja sanoo: Suomesi on jo hyvää.",
          "path": "stories/new-student/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Uusi opiskelija",
        "path": "stories/new-student/title.mp3"
      }
    },
    "weather-today": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Tänään ulkona on kylmä, mutta aurinko paistaa.",
          "path": "stories/weather-today/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Minä laitan lämpimän takin päälle ja menen bussilla.",
          "path": "stories/weather-today/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Ystäväni sanoo: Huomenna on ehkä lämpimämpää.",
          "path": "stories/weather-today/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Minä vastaan: Se on hyvä uutinen.",
          "path": "stories/weather-today/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Sää tänään",
        "path": "stories/weather-today/title.mp3"
      }
    },
    "after-work-shop": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Työn jälkeen Jun menee pieneen kauppaan.",
          "path": "stories/after-work-shop/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Hän ostaa leipää, maitoa ja kahvia.",
          "path": "stories/after-work-shop/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Jun katsoo rahojaan ja ajattelee: Täksi päiväksi tämä riittää.",
          "path": "stories/after-work-shop/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Sitten hän menee tyytyväisenä kotiin.",
          "path": "stories/after-work-shop/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Kauppaan työn jälkeen",
        "path": "stories/after-work-shop/title.mp3"
      }
    },
    "supermarket-evening": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Ying menee isoon ruokakauppaan työpäivän jälkeen.",
          "path": "stories/supermarket-evening/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Hän vertaa kahden jogurtin hintaa ja huomaa, että toinen on halvempi.",
          "path": "stories/supermarket-evening/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Hedelmäosastolla omenat näyttävät hyviltä, mutta mansikat ovat tänään liian kalliita.",
          "path": "stories/supermarket-evening/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Lopuksi Ying ostaa vain sen, mitä hän oikeasti tarvitsee.",
          "path": "stories/supermarket-evening/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Ilta supermarketissa",
        "path": "stories/supermarket-evening/title.mp3"
      }
    },
    "library-card": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Bo menee kirjastoon, koska hän haluaa tehdä kirjastokortin.",
          "path": "stories/library-card/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Työntekijä pyytää hänen nimeään, osoitettaan ja puhelinnumeroaan.",
          "path": "stories/library-card/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Bo kirjoittaa tiedot hitaasti ja tarkistaa ne vielä kerran.",
          "path": "stories/library-card/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Kun kortti on valmis, hän lainaa heti yhden helpon suomenkielisen kirjan.",
          "path": "stories/library-card/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Kirjastokortti",
        "path": "stories/library-card/title.mp3"
      }
    },
    "meeting-neighbor": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Illalla Lan kohtaa uuden naapurinsa käytävässä.",
          "path": "stories/meeting-neighbor/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "He tervehtivät toisiaan ja puhuvat hetken talosta.",
          "path": "stories/meeting-neighbor/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Naapuri sanoo, että talo on yleensä hyvin rauhallinen.",
          "path": "stories/meeting-neighbor/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Lan ilahtuu siitä, koska hän haluaa opiskella kotona iltaisin.",
          "path": "stories/meeting-neighbor/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Juttelu naapurin kanssa",
        "path": "stories/meeting-neighbor/title.mp3"
      }
    },
    "wrong-bus-stop": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Hao jää bussista pois liian aikaisin ja huomaa heti olevansa väärässä paikassa.",
          "path": "stories/wrong-bus-stop/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Hän kysyy ohikulkijalta, miten hän pääsee takaisin asemalle.",
          "path": "stories/wrong-bus-stop/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Ohikulkija neuvoo: Mene suoraan, käänny vasemmalle ja ota seuraava bussi.",
          "path": "stories/wrong-bus-stop/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Hao on vähän myöhässä, mutta hän oppii samalla monta hyödyllistä sanaa.",
          "path": "stories/wrong-bus-stop/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Väärällä pysäkillä",
        "path": "stories/wrong-bus-stop/title.mp3"
      }
    },
    "study-group": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Kolme opiskelijaa kokoontuu kirjastoon tekemään yhdessä tehtävää.",
          "path": "stories/study-group/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Yksi heistä sanoo, että opettaja puhuu joskus liian nopeasti tunnilla.",
          "path": "stories/study-group/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Toinen vastaa, että asia helpottuu, kun puhuu enemmän ja harjoittelee ääneen.",
          "path": "stories/study-group/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Lopulta ryhmä päättää tavata ensi viikolla uudelleen ja jatkaa yhdessä opiskelua.",
          "path": "stories/study-group/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Opintoryhmä",
        "path": "stories/study-group/title.mp3"
      }
    },
    "doctor-call": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Mei ei voi hyvin, joten hän soittaa terveysasemalle aamulla.",
          "path": "stories/doctor-call/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Puhelimessa hän kertoo nimensä ja sanoo haluavansa varata ajan lääkärille.",
          "path": "stories/doctor-call/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Hoitaja kysyy hänen henkilötietonsa ja ehdottaa aikaa seuraavalle päivälle.",
          "path": "stories/doctor-call/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Puhelun jälkeen Mei kirjoittaa ajan ylös ja miettii, missä lähin apteekki on.",
          "path": "stories/doctor-call/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Lääkäriajan varaaminen",
        "path": "stories/doctor-call/title.mp3"
      }
    },
    "apartment-viewing": {
      "paragraphs": [
        {
          "index": 1,
          "text": "Jun käy katsomassa pientä asuntoa, joka on lähellä hänen työpaikkaansa.",
          "path": "stories/apartment-viewing/paragraphs/01.mp3"
        },
        {
          "index": 2,
          "text": "Välittäjä näyttää ensin olohuoneen, sitten keittiön ja lopuksi pienen makuuhuoneen.",
          "path": "stories/apartment-viewing/paragraphs/02.mp3"
        },
        {
          "index": 3,
          "text": "Jun kysyy, onko alue rauhallinen iltaisin ja onko lähellä ruokakauppa.",
          "path": "stories/apartment-viewing/paragraphs/03.mp3"
        },
        {
          "index": 4,
          "text": "Kun hän lähtee pois, hän ei vielä tiedä, onko tämä oikea asunto hänelle, mutta paikka tuntuu lupaavalta.",
          "path": "stories/apartment-viewing/paragraphs/04.mp3"
        }
      ],
      "title": {
        "text": "Asuntonaytto",
        "path": "stories/apartment-viewing/title.mp3"
      }
    }
  }
}