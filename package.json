{
  "name": "finnish-learning-for-chinese",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client --port 8083",
    "android": "expo run:android --port 8083",
    "android:emu": "expo run:android --port 8083",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8083",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "audio:manifest": "python3 scripts/build_audio_asset_manifest.py",
    "audio:bundle": "python3 scripts/convert_audio_to_mp3.py --input-dir out/audio --output-dir assets/audio --force && python3 scripts/build_audio_asset_manifest.py"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~55.0.9",
    "expo-audio": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.13",
    "react-refresh": "^0.14.2",
    "typescript": "~5.9.2"
  }
}
